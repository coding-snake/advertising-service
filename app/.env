#/---| APP_ENV
# Possible values: 'prod', 'dev', 'test'
#
# If APP_ENV='dev'  then certain values are overwritten using '.env.dev'  file
# If APP_ENV='test' then certain values are overwritten using '.env.test' file

APP_ENV='dev'
#\---|


#/---| APP_SECRET
#
# Used for encryption of sensitive data
# REMEMBER to change it in production

APP_SECRET='my_secret_key_for_prod'
#\---|

#/---| DATABASE_URL
#
# Used to communicate with your production database
# During production : remember to change values enclosed in {} brackets

DATABASE_URL='mysql://{username}:{password}@{host}:{port}/{database}}'
#\---|

#/---| DEFAULT_URI
#
# Default endpoint for application

DEFAULT_URI=http://localhost
#\---|


APP_SHARE_DIR=var/share

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

MAILER_DSN=null://null
