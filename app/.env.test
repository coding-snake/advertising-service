#/---| KERNEL
#
# In namespace 'App' value 'Kernel'
# Used to define environment for testing

KERNEL_CLASS='App\Kernel'
#\---|

#/---| APP_SECRET
#
# Used for encryption of sensitive data

APP_SECRET='my_secret_key_for_test'
#\---|


#/---| DATABASE_URL
#
# Used to communicate with your testing database

DATABASE_URL='mysql://symfony_test:symfony_test@mysql:3306/symfony_test'
#\---|